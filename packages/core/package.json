{
    "name": "@buxton/core",
    "version": "0.0.17",
    "license": "MIT",
    "author": "Chris Liu",
    "files": [
        "dist/*.js",
        "types/**"
    ],
    "type": "module",
    "module": "./dist/index.js",
    "types": "./types",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        },
        "./global": {
            "import": "./dist/global.js"
        },
        "./polyfill": {
            "import": "./dist/polyfill.js",
            "types": "./types/polyfill.d.ts"
        }
    },
    "scripts": {
        "dev": "tsup --watch --onSuccess \"pnpm prebuild && pnpm postbuild\" ",
        "clean": "rm -rf ./dist",
        "prebuild": "tsup --dts-only",
        "build": "tsup --no-dts",
        "postbuild": "mv -f dist/index.d.ts types/lib.d.ts && rm -f dist/*.d.ts",
        "release": "pnpm run clean && pnpm run build",
        "test": "vitest"
    },
    "dependencies": {
    },
    "peerDependencies": {
        "chalk": ">=5",
        "mitt": ">=3"
    },
    "devDependencies": {
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    },
    "publishConfig": {
        "access": "public"
    }
}
