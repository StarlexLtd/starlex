{
    "name": "@buxton/ag-grid",
    "version": "0.0.1",
    "license": "MIT",
    "author": "Chris Liu",
    "files": [
        "dist/*.js",
        "types/**"
    ],
    "type": "module",
    "module": "./dist/index.js",
    "types": "./types",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./types/index.d.ts"
        },
        "./floating-filter": {
            "import": "./dist/floating-filter.js",
            "types": "./types/floating-filter.d.ts"
        },
        "./floating-filter.css": "./dist/floating-filter.css"
    },
    "sideEffects": [
        "*.css"
    ],
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "release": "pnpm run clean && pnpm run build",
        "test": "vitest"
    },
    "dependencies": {
        "@mdi/js": "catalog:",
        "lodash-es": "catalog:"
    },
    "peerDependencies": {
        "@ag-grid-community/client-side-row-model": "catalog:",
        "@ag-grid-community/core": "catalog:",
        "@ag-grid-community/locale": "catalog:",
        "@ag-grid-community/styles": "catalog:",
        "@buxton/core": "workspace:*"
    },
    "devDependencies": {
        "@ag-grid-community/client-side-row-model": "catalog:",
        "@ag-grid-community/core": "catalog:",
        "@ag-grid-community/locale": "catalog:",
        "@ag-grid-community/styles": "catalog:",
        "@buxton/core": "workspace:*",
        "@microsoft/api-extractor": "catalog:",
        "@sveltejs/vite-plugin-svelte": "catalog:",
        "@tailwindcss/vite": "catalog:",
        "@types/lodash-es": "catalog:",
        "daisyui": "catalog:",
        "svelte": "catalog:",
        "tailwindcss": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vite-plugin-dts": "catalog:",
        "vitest": "catalog:"
    },
    "publishConfig": {
        "access": "public"
    }
}
