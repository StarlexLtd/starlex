{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "baseUrl": ".",
        "paths": {
            "$": ["./src/"],
            "$/*": ["./src/*"],
        },
    },
    "include": [
        "./src/**/*.ts",
        "./src/**/*.tsx",
        "./src/**/*.svelte",
        "./types/**/*.d.ts",
    ],
    "exclude": [
        "./src/old/**",
    ],
}
